#!/usr/bin/env bash
set -euo pipefail

fish -lc '
functions -q tide; or exit 0

tide configure --auto \
  --style=Lean \
  --prompt_colors="16 colors" \
  --show_time=No \
  --lean_prompt_height="Two lines" \
  --prompt_connection=Disconnected \
  --prompt_spacing=Sparse \
  --icons="Few icons" \
  --transient=Yes
'
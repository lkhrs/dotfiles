// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "buffer_font_size": 13.0,
  "buffer_font_family": "JetBrains Mono",
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "context_servers": {
    "chrome-devtools-mcp-zed": {
      "enabled": true,
      "remote": false,
      "settings": {
        "browser_url": null,
        "ws_endpoint": null,
        "ws_headers": null,
        "auto_connect": null,
        "channel": null,
        "headless": null,
        "isolated": null,
        "user_data_dir": null,
        "viewport": null,
        "executable_path": null,
        "chrome_arg": [],
        "proxy_server": null,
        "accept_insecure_certs": null,
        "category_emulation": null,
        "category_performance": null,
        "category_network": null,
        "log_file": null,
        "extra_args": [],
      },
    },
  },
  "proxy": "",
  "context_server_timeout": 60,
  "outline_panel": {
    "dock": "right",
  },
  "semantic_tokens": "combined",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_config_options": {
        "reasoning_effort": "medium",
        "model": "gpt-5.5",
      },
      "favorite_config_option_values": {
        "reasoning_effort": ["medium"],
        "model": ["gpt-5.4-mini", "gpt-5.5"],
      },
    },
  },
  "scroll_beyond_last_line": "off",
  "git_panel": {
    "show_count_badge": true,
    "file_icons": true,
    "collapse_untracked_diff": true,
    "dock": "right",
    "tree_view": false,
  },
  "toolbar": {
    "code_actions": true,
  },
  "snippet_sort_order": "top",
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "project_panel": {
    "hide_hidden": false,
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "dock": "right",
    "sort_mode": "directories_first",
    "hide_root": true,
  },
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": false,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "ui_font_family": ".SystemUIFont",
  "disable_ai": false,
  "inlay_hints": {
    "enabled": true,
    "show_background": false,
  },
  "redact_private_values": true,
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "completions": {
    "lsp_fetch_timeout_ms": 0,
  },
  "max_tabs": 10,
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "scrollbar": {
    "axes": {},
  },
  "agent": {
    "flexible": true,
    "play_sound_when_agent_done": "always",
    "sidebar_side": "left",
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "favorite_models": [
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.5",
        "enable_thinking": true,
        "effort": "medium",
      },
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.4-mini",
        "enable_thinking": true,
        "effort": "medium",
      },
    ],
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
  },
  "show_edit_predictions": true,
  "edit_predictions": {
    "allow_data_collection": "no",
    "provider": "copilot",
    "disabled_globs": [""],
  },
  "languages": {
    "Go": {
      "show_edit_predictions": true,
    },
    "Rust": {
      "show_edit_predictions": true,
    },
    "Markdown": {
      "show_edit_predictions": false,
    },
    "PHP": {
      "show_edit_predictions": true,
      "language_servers": ["!phptools", "!intelephense", "..."],
    },
    "Caddyfile": {
      "format_on_save": "on",
      "tab_size": 2,
      "formatter": {
        "external": {
          "command": "caddy",
          "arguments": ["fmt", "-"],
        },
      },
    },
    "Python": {
      "language_servers": ["ty", "!basedpyright", "!pyright", "ruff"],
    },
  },
  "base_keymap": "SublimeText",
  "cursor_blink": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "calls": {
    "mute_on_join": true,
    "share_on_join": false,
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_sign_in": true,
    "show_user_picture": false,
    "show_onboarding_banner": false,
  },
  // Save
  "format_on_save": "on",
  "autosave": "on_focus_change",
  // stop adding/removing whitespace in files
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": false,
  "lsp": {
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemaStore": {
            "enable": false,
          },
        },
      },
    },
  },
  "file_types": {
    "Caddyfile": ["Caddyfile*", "*.caddyfile"],
    "Blade": ["*.blade.php"],
  },
  "load_direnv": "shell_hook",
  "minimap": {},
  "auto_install_extensions": {
    "astro": true,
    "basher": true,
    "caddyfile": true,
    "dockerfile": true,
    "csv": true,
    "emmet": true,
    "env": true,
    "fish": true,
    "git-firefly": true,
    "go-snippets": true,
    "gosum": true,
    "html": true,
    "ini": true,
    "log": true,
    "lua": true,
    "make": true,
    "marksman": true,
    "php": true,
    "ssh-config": true,
    "toml": true,
    "typos": true,
    "xml": true,
    "react-typescript-snippets": true,
    "snippets": true,
    "zed-php-snippets": true,
    "zed-comment": true,
    "editor-config-zed": true,
    "codeowners-zed": true,
  },
  // "helix_mode": true
}
